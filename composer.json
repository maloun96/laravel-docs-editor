{
    "name": "maloun96/laravel-docs-editor",
    "description": "Admin panel for editing markdown documentation with GitHub PR workflow",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Maloun96\\DocsEditor\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maloun96\\DocsEditor\\DocsEditorServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
